<idea-plugin>
    <id>com.fmagent.deveco.minimal</id>
    <name>FM Agent DevEco Minimal</name>
    <vendor>FM Agent</vendor>
    <version>0.6.0</version>

    <idea-version since-build="243" until-build="243.*"/>

    <description>
        DevEco Studio plugin that installs/runs FM-Agent and displays reasoning results.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action
            id="com.fmagent.deveco.ShowProjectInfoAction"
            class="com.fmagent.deveco.ShowProjectInfoAction"
            text="FM Agent: Open Panel"
            description="Open the FM-Agent runner panel">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
            id="FM Agent"
            anchor="right"
            factoryClass="com.fmagent.deveco.FmAgentToolWindowFactory"/>
    </extensions>
</idea-plugin>
